{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "MatchHub (API + Flutter)",
      "configurations": [
        "MatchHub API",
        "Flutter App"
      ],
      "preLaunchTask": "MatchHub: Build Backend",
      "stopOnEntry": false
    }
  ],
  "configurations": [
    {
      "name": "MatchHub API",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/backend/MatchHub.Api/MatchHub.Api.csproj",
        "--configuration",
        "Debug"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "internalConsoleOptions": "neverOpen",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Flutter App",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/apps/matchhub_flutter/lib/main.dart",
      "cwd": "${workspaceFolder}/apps/matchhub_flutter",
      "args": [
        "--dart-define=MATCHHUB_API_URL=http://localhost:5270",
        "--dart-define=MATCHHUB_API_TOKEN=test-token"
      ]
    },
    {
      "name": "MatchHub API (Debug)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/backend/MatchHub.Api/MatchHub.Api.csproj",
        "--configuration",
        "Debug"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "sourceLanguages": [
        "csharp"
      ],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Backend Tests",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/MatchHub.Api.Tests/MatchHub.Api.Tests.csproj",
        "--verbosity=minimal"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}
